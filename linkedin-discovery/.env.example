# === Discovery (Serper) ===
GROQ_API_KEY=
# Fara SERPER_API_KEY, discovery-ul cauta GRATIS prin ddgs (DuckDuckGo).
SERPER_API_KEY=

# === Scraper box (Bright Data -> Apify -> RapidAPI -> ScraperAPI) ===
# Bright Data (PRINCIPAL, recomandat): 5000 profile/luna GRATIS, robust.
# Token de la https://brightdata.com/cp/setting/users
BRIGHTDATA_TOKEN=
# Dataset LinkedIn people profiles (implicit ok; schimba doar daca ai alt id):
# BRIGHTDATA_DATASET=gd_l1viktl72bvl7bjuj0

# Apify: token gratis de la https://console.apify.com (~1200 profile/luna gratis)
APIFY_TOKEN=
APIFY_ACTOR=harvestapi~linkedin-profile-scraper
# RapidAPI (fallback): cheie gratis de la rapidapi.com -> "linkedin-data-api"
RAPIDAPI_KEY=
RAPIDAPI_HOST=linkedin-data-api.p.rapidapi.com
RAPIDAPI_PATH=/get-profile-data-by-url
# Pentru MAI MULTA cota gratis: aboneaza-te (Basic $0) si la aceste API-uri LinkedIn de
# pe RapidAPI — fiecare are cota lui gratuita, aceeasi cheie. Codul roteste automat:
#   - linkedin-api8.p.rapidapi.com
#   - fresh-linkedin-profile-data.p.rapidapi.com
# Optional, poti da lista ta explicita (host,path,param separate cu ;):
# RAPIDAPI_ENDPOINTS=linkedin-data-api.p.rapidapi.com,/get-profile-data-by-url,url;linkedin-api8.p.rapidapi.com,/get-profile-data-by-url,url

# ScraperAPI (fallback): https://www.scraperapi.com
SCRAPERAPI_KEY=

# Optional overrides (defaults shown):
# GROQ_MODEL=llama-3.3-70b-versatile
# SERP_PAGES=2
# SERP_GL=us
# SERP_HL=en

#Uvicorn API URL
UVICORN_API=http://127.0.0.1:8000/api/discover
